rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get the current user's record
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if user is an Admin
    function isAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'admin' || 
        request.auth.token.email == 'financestudio2026@gmail.com' ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) // Allow bootstrapping the first user
      );
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Rules for Vehicles collection
    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Drivers collection
    match /drivers/{driverId} {
      allow read: if isAuthenticated() && (request.auth.uid == driverId || isAdmin());
      allow write: if isAdmin();
    }

    // Rules for Expenses collection
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.loggedBy == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.loggedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
